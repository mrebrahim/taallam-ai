{
  "expo": {
    "name": "Taallam AI",
    "slug": "taallam-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "taallam",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ibrahimschool.taallam",
      "buildNumber": "1",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "عشان نبعتلك تذكير بدرسك اليومي وتحافظ على الـ streak"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#58CC02"
      },
      "package": "com.ibrahimschool.taallam",
      "versionCode": 1,
      "permissions": []
    },
    "plugins": [
      "expo-router",
      "expo-screen-capture",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#58CC02",
          "sounds": [],
          "androidMode": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}