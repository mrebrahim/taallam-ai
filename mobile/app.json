{
  "expo": {
    "name": "Taallam AI",
    "slug": "taallam-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "taallam",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ibrahimschool.taallam",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "عشان ترفع screenshots للتحديات",
        "NSPhotoLibraryUsageDescription": "عشان ترفع صور للتحديات",
        "NSUserNotificationUsageDescription": "عشان نبعتلك تذكير بدرسك اليومي وتحافظ على الـ streak"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#58CC02"
      },
      "package": "com.ibrahimschool.taallam",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-screen-capture",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#58CC02",
          "androidMode": "default"
        }
      ],
      [
        "expo-av",
        { "microphonePermission": false }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "your-expo-project-id"
      }
    }
  }
}
