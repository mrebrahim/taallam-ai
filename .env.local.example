# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://raskcogecjfwuxvwldzp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── Stripe ──
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_ELITE_YEARLY=price_...

# ── App ──
NEXT_PUBLIC_APP_URL=https://taallam.n8nar.com

# ══════════════════════════════════════════
# SETUP CHECKLIST:
# 1. Fill in Supabase keys from:
#    https://supabase.com/dashboard/project/raskcogecjfwuxvwldzp/settings/api
#
# 2. Enable Google OAuth in Supabase:
#    Authentication → Providers → Google
#    Add redirect URL: https://taallam.n8nar.com/api/auth/callback
#
# 3. Enable Apple OAuth in Supabase:
#    Authentication → Providers → Apple
#    (Requires Apple Developer Account)
#
# 4. Create Stripe products:
#    - Pro Monthly: $10/month recurring
#    - Elite Yearly: $100/year recurring
#    Copy the price IDs above
#
# 5. Set up Stripe webhook:
#    Endpoint: https://taallam.n8nar.com/api/stripe/webhook
#    Events to listen:
#      - checkout.session.completed
#      - invoice.payment_succeeded
#      - invoice.payment_failed
#      - customer.subscription.deleted
